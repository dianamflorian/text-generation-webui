+def minify_css(css: str) -> str:
+                             
+    css = re.sub(r'/\*.*?\*/', '', css, flags=re.DOTALL)
+
+    css = re.sub(r'^[ \t]*|[ \t]*$', '', css, flags=re.MULTILINE)
+
+    css = re.sub(r'([:{;,])\s+', r'\1', css)
+
+    css = re.sub(r'\s+{', '{', css)
+
+    css = re.sub(r'^\s*$', '', css, flags=re.MULTILINE)
+
+    css = re.sub(r'\n', '', css)
+
+    return css
+
